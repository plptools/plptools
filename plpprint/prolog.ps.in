%%BeginResource: plpprint_prolog @VERSION@ 0
/bd{bind def}bind def
/ed{exch def}bd
/d{def}bd
/e{exch}bd
/twips{1440 div 72 mul}bd
/pixel{10 twips mul}bd
/ul false d
/st false d
/bg[0 0 0]d
/fg[0 0 0]d
/pen_st 0 d
/pen_th 0 d
/brush_st 0 d
/dofill false d
/parray 6 array d
/EpocEncoding ISOLatin1Encoding 256 array copy dup 128
[/Euro/.notdef/quotesinglbase/florin/quotedblbase/ellipsis/dagger/daggerdbl
/circumflex/perthousand/Scaron/guilsinglleft/OE/.notdef/Zcaron/.notdef
/.notdef/quoteleft/quoteright/quotedblleft/quotedblright/bullet/endash
/emdash/tilde/trademark/scaron/guilsinglright/oe/.notdef/zcaron/ydieresis]
putinterval d
/dashes[[][1 2][3][1 2 3 2][1 2 1 2 3 2]]d
/s{
  pen_st 0 ne{
    dashes pen_st 1 sub get 0 setdash
    currentpoint stroke moveto
  }if
}bd
/bp1{begin 0 setgray}bd
/bp2{lineto s end}bd
/bps[
  {bp1 0 0 moveto 0 8 bp2}bind
  {bp1 0 0 moveto 8 8 bp2}bind
  {bp1 0 0 moveto 8 0 bp2}bind
  {bp1 0 8 moveto 8 0 bp2}bind
  {bp1 0 8 moveto 0 0 lineto 8 0 bp2}bind
  {bp1 0 0 moveto 8 8 lineto s 0 8 moveto 8 0 bp2}bind
]d
/ip{ % init patterns
  0 1 5{
    /i ed
    parray i
    <<
      /PatternType 1
      /PaintType 1
      /TilingType 2
      /BBox [0 0 8 8]
      /XStep 8
      /YStep 8
    >> dup/PaintProc bps i get put
    matrix makepattern put
  }for
}bd
/fs{ % fontvalue fs pointvalue
  1000 div 24 mul
}bd
/m{
  pageheight e sub moveto
}bd
/mb{
  moveby
}bd
/l{
  pageheight e sub lineto
}bd
/f{
  dofill{
    gsave
    fill
    grestore
    brush_st 2 gt{
      gsave
      parray brush_st 3 sub get setpattern
      fill
      grestore
      /DeviceRGB setcolorspace
      fg SC
    }if
  }if
}bd
/ef{
  dofill{
    gsave
    eofill
    grestore
    brush_st 2 gt{
      gsave
      parray brush_st 3 sub get setpattern
      eofill
      grestore
      /DeviceRGB setcolorspace
      fg SC
    }if
  }if
}bd
/UL{
  1 eq/ul ed
}bd
/ST{
  1 eq/st ed
}bd
/BG{ % r g b BG - (store background color)
  mark 4 1 roll ]/bg ed
}bd
/FG{ % r g b FG - (store foreground color)
  mark 4 1 roll ]/fg ed
}bd
/RC{ % - RC - (reset colors)
  0 BS
  0 0 0 FG
}bd
/SC{ % colorarray SC - (set stored color)
  dup 0 get 255 div e
  dup 1 get 255 div e
  2 get 255 div
  setrgbcolor
}bd
/F{
  findfont
  % reencode for ISOLatin1. (From redbook sec. 5.6.1) and add some
  % special symbols, resulting in an EPOC encoding
  dup length dict begin
    {
      1 index dup/FID ne{
        /CharStrings ne{
          d
        }{
          % must copy CharStrings dict to make it writeable
          dup length dict begin{def}forall
          % copy /Euro charstring from Symbol font
          /Euro /Symbol findfont /CharStrings get /Euro get def
          currentdict end d
        }ifelse
      }{
        pop pop pop
      }ifelse
    }forall
    % Replace encoding
    /Encoding EpocEncoding d
    currentdict
  end dup/FontName get 80 string cvs (-EPOCLatin15) concatstrings cvn
  e definefont
  % end of reencoding
  e twips scalefont setfont
}bd
/MT{ % x y MT - (move to)
    twips e twips e m
}bd
/MB{ % x y MB - (move by)
    twips e twips e moveby
}bd
/PT{ % x y PT - (draw point)
  2 dict begin
    twips/y ed
    twips/x ed
    newpath x y pageheight e sub pen_th 2 div 0 360 arc closepath fg SC fill
    newpath
  end
}bd
/L{ % x1 y1 x2 y2 L - (draw line from x1,y1 to x2,y2)
  4 -1 roll twips 4 -1 roll twips m
  twips e twips e l fg SC s
}bd
/LT{ % x y LT - (draw line to x,y)
  twips e twips e l fg SC s
}bd
/LB{ % x y LB - (draw line by x,y)
  twips e twips e rlineto fg SC s
}bd
/R{ % left top right bottom R - (draw rectangle)
  4 dict begin
    twips/y2 ed
    twips/x2 ed
    twips/y1 ed
    twips/x1 ed
    newpath
    x1 y1 m x2 y1 l x2 y2 l x1 y2 l
    closepath
    gsave bg SC f grestore fg SC s
    newpath
  end
}bd
/RR{ % left top right bottom cornerwidth cornerheight RR - (draw rounded rectangle)
  7 dict begin
    twips/ch ed
    twips/cw ed
    twips/bottom ed
    twips/right ed
    twips/top ed
    twips/left ed

    cw right left sub 2 div gt{/cw right left sub 2 div d}if
    ch bottom top sub 2 div gt{/ch bottom top sub 2 div d}if
    /radius cw ch lt{cw}{ch}ifelse d

    newpath
    right radius sub top m
    right radius sub pageheight top radius add sub radius 90 0 arcn
    right bottom radius sub l
    right radius sub pageheight bottom radius sub sub radius 0 -90 arcn
    left radius add bottom l
    left radius add pageheight bottom radius sub sub radius -90 -180 arcn
    left top radius add l
    left radius add pageheight top radius add sub radius -180 90 arcn
    closepath
    gsave bg SC f grestore fg SC s
    newpath
  end
}bd
/E{ % left top right bottom E - (draw ellipse)
  6 dict begin
    twips /bottom ed
    twips /right ed
    twips /top ed
    twips /left ed
    /w right left sub d
    /h bottom top sub d

    newpath
    matrix currentmatrix
      left w 2 div add pageheight top sub h 2 div sub translate
      1 h w div scale
      w 2 div 0 moveto
      0 0 w 2 div 0 360 arc
    setmatrix
    closepath
    gsave bg SC f grestore fg SC s
    newpath
  end
}bd
/A { % left top right bottom x1 y1 x2 x2 A - (draw arc)
  14 dict begin
    twips /y2 ed
    twips /x2 ed
    twips /y1 ed
    twips /x1 ed
    twips /bottom ed
    twips /right ed
    twips /top ed
    twips /left ed

    /x0 left right add 2 div d
    /y0 top bottom add 2 div d
    /rx right left sub abs 2 div d
    /ry bottom top sub abs 2 div d

    /a1 y0 y1 sub ry div  x1 x0 sub rx div atan d
    /a2 y0 y2 sub ry div  x2 x0 sub rx div atan d

    newpath
    matrix currentmatrix
      x0 pageheight y0 sub translate
      rx ry scale
      0 0 1 a1 a2 arc
    setmatrix
    fg SC s
    newpath
  end
}bd
/AP { % left top right bottom x1 y1 x2 x2 A - (draw arc pie)
  18 dict begin
    twips /y2 ed
    twips /x2 ed
    twips /y1 ed
    twips /x1 ed
    twips /bottom ed
    twips /right ed
    twips /top ed
    twips /left ed

    /x0 left right add 2 div d
    /y0 top bottom add 2 div d
    /rx right left sub abs 2 div d
    /ry bottom top sub abs 2 div d

    /a1 y0 y1 sub ry div  x1 x0 sub rx div atan d
    /a2 y0 y2 sub ry div  x2 x0 sub rx div atan d

    newpath
    matrix currentmatrix
      x0 pageheight y0 sub translate
      rx ry scale
      0 0 1 a1 a2 arc
    setmatrix
    x0 y0 l
    closepath
    gsave bg SC f grestore fg SC s
    newpath
  end
}bd
/PL{ % pointarray PL - (draw polyline)
  4 dict begin
    /points ed
    newpath
    0 2 points length 1 sub{
      /idx ed
      points idx get twips
      points idx 1 add get twips
      idx 0 eq{m}{l}ifelse
    }for
    fg SC s
    newpath
  end
}bd
/PG{ % pointarray eofill PG - (draw polygon)
  5 dict begin
    /efmode ed
    /points ed
    newpath
    0 2 points length 1 sub{
      /idx ed
      points idx get twips
      points idx 1 add get twips
      idx 0 eq{m}{l}ifelse
    }for
    closepath
    gsave bg SC efmode{ef}{f}ifelse grestore fg SC s
    newpath
  end
}bd
/spacecount{ % string spacecount
  /str ed
  /cnt 0 d
  0 1 str length 1 sub{str e get 32 eq{/cnt cnt 1 add d}if}for
  cnt
}bd
/T{ % string left bottom top right justify T - (draw text)
  8 dict begin
    /just ed
    twips/x2 ed
    twips/y2 ed
    twips/y1 ed
    twips/x1 ed
    dup stringwidth pop/sw ed
    x2 0 eq{/x2 x1 sw add d}if
    x2 x1 sub sw sub/extra ed
    just 0 gt{
      just 1 gt{x2 sw sub}{x2 x1 sub sw sub 2 div x1 add}ifelse
    }{x1}ifelse

    y1 m
    ul{
      gsave
        currentfont/FontInfo known{
          currentfont/FontInfo get begin
            0 UnderlinePosition fs rmoveto
            UnderlineThickness fs setlinewidth
          end
        }{
          gsave newpath 0 0 moveto (_) false charpath pathbbox e pop e sub e pop grestore
          dup 0 e neg 2 mul rmoveto setlinewidth
        }ifelse
        sw 0 rlineto s
        pen_th setlinewidth
      grestore
    }if
    st{
      gsave
        gsave newpath 0 0 moveto (I) false charpath pathbbox e pop e sub e pop 2 div 0 e grestore
        rmoveto
        gsave newpath 0 0 moveto (_) false charpath pathbbox e pop e sub e pop grestore
        setlinewidth
        sw 0 rlineto s
        grestore
    }if
    fg SC
    dup spacecount dup 0 gt extra 0 lt and{extra e div 0 32 4 -1 roll widthshow}{pop show}ifelse
  end
}bd
/I{ % left bottom right top width height I - (image)
  7 dict begin
    /height ed
    /width ed
    twips/top ed
    twips/right ed
    twips/bottom ed
    twips/left ed
    /ibuf width string d
    gsave
      left pageheight bottom sub translate
      right left sub bottom top sub scale
      width height 8 [width 0 0 height neg 0 height]
      {currentfile ibuf readhexstring pop}image
    grestore
  end
}bd
/IC{ % left bottom right top width height srcleft srcbottom srcright srctop IC - (image cropped)
  14 dict begin
    /srctop ed
    /srcright ed
    /srcbottom ed
    /srcleft ed
    /height ed
    /width ed
    twips/top ed
    twips/right ed
    twips/bottom ed
    twips/left ed
    /linebuf width string d
    /ibuf srcright srcleft sub string d
    /leftbuf srcleft string d
    /rightbuf width srcright sub string d
    gsave
      left pageheight bottom sub translate
      right left sub bottom top sub scale
      0 1 height srctop sub 1 sub {currentfile linebuf readhexstring pop pop}for  % skip first rows
      srcright srcleft sub srctop srcbottom sub 8 [srcright srcleft sub 0 0 srctop srcbottom sub neg 0 srctop srcbottom sub]
      {
          currentfile leftbuf readhexstring pop pop  % skip first cols
          currentfile ibuf readhexstring pop
          currentfile rightbuf readhexstring pop pop  % skip last cols
      }image
      0 1 srcbottom 1 sub {currentfile linebuf readhexstring pop pop} for  % skip last rows
    grestore
  end
}bd
/TH{ % xwid ywid TH - (set pen thickness, ignoring ywid)
  pop twips /pen_th ed
  pen_th setlinewidth
}bd
/DM{ % mode DM - (set drawing mode)
  pop
}bd
/PS{ % style PS - (set pen style)
  /pen_st ed
}bd
/BS{ % style BS - (set brush style)
  dup/brush_st ed
  0 ne/dofill ed
}bd
/CB{ % left top right bottom CB - (clipping bbox)
  4 dict begin
    twips/y2 ed
    twips/x2 ed
    twips/y1 ed
    twips/x1 ed
    newpath
    x1 y1 m x2 y1 l x2 y2 l x1 y2 l closepath clip
    newpath
  end
}bd
/CC{ % - CC - (restore clipping)
  initclip
}bd
%%EndResource
